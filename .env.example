# Read by `docker compose` (not by `npm run dev` — that reads
# apps/api/.env, see apps/api/.env.example) for docker-compose.yml's
# ${ENCRYPTION_KEY} interpolation. Copy this file to .env at the repo root
# and fill it in before running `docker compose up --build`.

# Encrypts BYOK API keys that users opt into saving (workspace_api_keys
# table). Generate with: openssl rand -base64 32
ENCRYPTION_KEY=
